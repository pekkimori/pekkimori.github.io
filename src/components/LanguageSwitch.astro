---
type LanguageOption = {
  label: string;
  href: string;
  isActive: boolean;
};

type Props = {
  languageOptions: LanguageOption[];
};

const { languageOptions } = Astro.props;

const activeLanguageIndex = Math.max(
  0,
  languageOptions.findIndex(option => option.isActive)
);
---

{
  languageOptions.length > 1 && (
    <div
      class="focus-outline relative inline-flex items-center rounded-full border border-muted bg-muted p-1 transition-all duration-200 hover:border-accent/50"
      style={`--active-index:${activeLanguageIndex};--options-count:${languageOptions.length};`}
    >
      <span
        aria-hidden="true"
        class="lang-switch-pill pointer-events-none absolute top-1 bottom-1 left-1 rounded-full bg-background shadow-sm"
        style="width:calc((100% - 0.5rem) / var(--options-count));transform:translateX(calc(var(--active-index) * 100%));transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.3s ease,background-color 0.3s ease;"
      ></span>
      {languageOptions.map(option => (
        <a
          href={option.href}
          class:list={[
            "lang-switch-option relative z-10 rounded-full px-2 py-1 text-xs font-medium active:scale-90",
            option.isActive
              ? "text-accent"
              : "text-foreground/60 hover:text-foreground/90",
          ]}
          style="transition:color 0.3s ease,transform 0.15s ease;"
          aria-current={option.isActive ? "page" : undefined}
        >
          {option.label}
        </a>
      ))}
    </div>
  )
}

<script>
  import { navigate } from "astro:transitions/client";

  function initLanguageSwitch() {
    // Snap the pill to its correct position instantly on mount (no sliding animation)
    const pills = document.querySelectorAll<HTMLElement>(".lang-switch-pill");
    pills.forEach(pill => {
      const saved = pill.style.transition;
      pill.style.transition = "none";
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          pill.style.transition = saved;
        })
      );
    });

    document.querySelectorAll(".lang-switch-option").forEach((link, _, all) => {
      link.addEventListener("click", e => {
        if (link.getAttribute("aria-current") === "page") return;
        e.preventDefault();

        const href = (link as HTMLAnchorElement).href;
        const container = link.closest<HTMLElement>("[style*='--active-index']");

        // Update text colors immediately
        const newIndex = Array.from(all).indexOf(link);
        all.forEach((opt, i) => {
          if (i === newIndex) {
            opt.classList.add("text-accent");
            opt.classList.remove("text-foreground/60", "hover:text-foreground/90");
          } else {
            opt.classList.remove("text-accent");
            opt.classList.add("text-foreground/60", "hover:text-foreground/90");
          }
        });

        if (container) {
          container.style.setProperty("--active-index", String(newIndex));
        }

        navigate(href);
      });
    });
  }

  initLanguageSwitch();
  document.addEventListener("astro:after-swap", initLanguageSwitch);
</script>
