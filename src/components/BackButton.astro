---
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

type Props = {
  lang?: string;
};

const { lang } = Astro.props;

const goBackLabels: Record<string, string> = {
  en: "Go back",
  pt: "Voltar",
  ja: "戻る",
};

const goBackLabel = goBackLabels[lang ?? "en"] ?? "Go back";

const langHome: Record<string, string> = {
  en: "/en/",
  pt: "/pt/",
  ja: "/ja/",
};

const fallbackHref = langHome[lang ?? "en"] ?? "/en/";
---

{
  SITE.showBackButton && (
    <div class="app-layout flex items-center justify-start">
      <LinkButton
        id="back-button"
        href={fallbackHref}
        class="focus-outline -ms-2 mt-8 mb-2 hover:text-foreground/75"
      >
        <IconChevronLeft class="inline-block size-6 rtl:rotate-180" />
        <span>{goBackLabel}</span>
      </LinkButton>
    </div>
  )
}

<script>
  /* Update Back Button URL */
  function updateGoBackUrl() {
    const backButton: HTMLAnchorElement | null =
      document.querySelector("#back-button");

    const backUrl = sessionStorage.getItem("backUrl");

    if (backUrl && backButton) {
      // Adjust backUrl to always match the current page's language,
      // so switching language on a post page doesn't send the user back
      // to the previous language's listing.
      const currentLangMatch = location.pathname.match(/^\/(en|pt|ja)\//);
      if (currentLangMatch) {
        const currentLang = currentLangMatch[1];
        backButton.href = backUrl.replace(/^\/(en|pt|ja)\//, `/${currentLang}/`);
      } else {
        backButton.href = backUrl;
      }
    }
  }

  document.addEventListener("astro:page-load", updateGoBackUrl);
  updateGoBackUrl();
</script>
